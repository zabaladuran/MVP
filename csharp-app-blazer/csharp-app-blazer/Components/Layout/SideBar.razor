@rendermode InteractiveServer

<nav class="sidebar d-flex flex-column" style="width:260px; min-height:100vh; background:#fff; border-right:1px solid #ebebf0; padding:20px 12px;">

    @* Perfil de usuario *@
    <div class="d-flex align-items-center gap-3 mb-3 px-2">
        <div class="avatar-circle">
            <i class="bi bi-person-fill" style="font-size:22px; color:#6366f1;"></i>
        </div>
        <div>
            <p class="mb-0 fw-semibold" style="font-size:14px; color:#14141e;">@NombreUsuario</p>
            <p class="mb-0" style="font-size:12px; color:#6e6e82;">@Rol</p>
        </div>
    </div>

    @* Tienda activa *@
    <p class="sep-label">TIENDA ACTIVA</p>

    <div class="tienda-selector" style="cursor:pointer;">
        @* ✅ FIX 1: Se usa el método directamente en lugar de lambda inline *@
        <button type="button" class="tienda-btn w-100"
                @onclick="ToggleMenuTiendas">
            <i class="bi bi-shop"></i>
            <div>
                <div>@TiendaActual</div>
                <span class="badge-activa">Activa</span>
            </div>
            <i class="bi @(mostrarMenuTiendas ? "bi-chevron-up" : "bi-chevron-down")"></i>
        </button>

        @if (mostrarMenuTiendas)
        {
            <div class="tienda-menu">
                @foreach (var tienda in Tiendas)
                {
                    @* ✅ FIX 2: Se awaita correctamente el Task asíncrono *@
                    <button type="button"
                            class="tienda-opt w-100 @(tienda == TiendaActual ? "active" : "")"
                            @onclick="async () => await CambiarTienda(tienda)">
                        @tienda
                    </button>
                }
            </div>
        }
    </div>

    @* Dashboard *@
    <NavLink class="nav-btn w-100 text-start d-flex align-items-center gap-2"
             href="/dashboard"
             Match="NavLinkMatch.Prefix"
             style="padding:10px 14px; border-radius:10px; font-size:14px; text-decoration:none; color:#14141e; margin-bottom:2px;">
        <i class="ti ti-chart-bar" style="font-size:17px;"></i> Dashboard
    </NavLink>

    @* Gestión *@
    <p class="sep-label mt-2">GESTIÓN</p>
    <NavLink class="nav-btn w-100 text-start d-flex align-items-center gap-2"
             href="/productos"
             Match="NavLinkMatch.Prefix"
             style="padding:10px 14px; border-radius:10px; font-size:14px; text-decoration:none; color:#14141e; margin-bottom:2px;">
        <i class="ti ti-box" style="font-size:17px;"></i> Productos
    </NavLink>

    <p class="sep-label mt-2">VENTAS</p>
    <button class="nav-btn w-100 text-start" disabled style="opacity:0.4; padding:10px 14px; border-radius:10px; font-size:14px; margin-bottom:2px;">
        <i class="ti ti-shopping-cart me-2" style="font-size:17px;"></i> Pedidos
    </button>
    <button class="nav-btn w-100 text-start" disabled style="opacity:0.4; padding:10px 14px; border-radius:10px; font-size:14px; margin-bottom:2px;">
        <i class="ti ti-credit-card me-2" style="font-size:17px;"></i> Transacciones
    </button>

    <p class="sep-label mt-2">SOPORTE</p>
    <button class="nav-btn w-100 text-start" disabled style="opacity:0.4; padding:10px 14px; border-radius:10px; font-size:14px; margin-bottom:2px;">
        <i class="ti ti-clipboard-list me-2" style="font-size:17px;"></i> PQRS
    </button>
    <button class="nav-btn w-100 text-start" disabled style="opacity:0.4; padding:10px 14px; border-radius:10px; font-size:14px; margin-bottom:2px;">
        <i class="ti ti-settings me-2" style="font-size:17px;"></i> Configuración
    </button>

    @* Cerrar sesión *@
    <div class="mt-auto pt-3">
        <NavLink class="btn-cerrar w-100 d-flex align-items-center gap-2"
                 href="/login"
                 style="padding:10px 14px; border-radius:10px; font-size:14px; text-decoration:none;">
            <i class="ti ti-door-exit" style="font-size:17px;"></i> Cerrar sesión
        </NavLink>
    </div>

</nav>

@code {
    [Parameter] public string NombreUsuario { get; set; } = "Carlos Pérez";
    [Parameter] public string Rol { get; set; } = "Administrador";
    [Parameter] public List<string> Tiendas { get; set; } = new() { "Tienda Norte", "Tienda Centro", "Tienda Sur" };
    [Parameter] public EventCallback<string> OnStoreChanged { get; set; }

    private string TiendaActual { get; set; } = "Tienda Norte";
    private bool mostrarMenuTiendas = false;

    // ✅ FIX 1: Ahora sí se usa este método desde el botón
    private void ToggleMenuTiendas()
    {
        mostrarMenuTiendas = !mostrarMenuTiendas;
    }

    // ✅ FIX 2: El Task ahora se awaita correctamente desde la lambda del foreach
    private async Task CambiarTienda(string tienda)
    {
        TiendaActual = tienda;
        mostrarMenuTiendas = false;
        await OnStoreChanged.InvokeAsync(tienda);
    }
}