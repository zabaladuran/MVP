@inherits LayoutComponentBase

<div class="d-flex flex-column" style="min-height: 100vh;">
    
    <!-- PWA Navbar -->
    <nav class="navbar navbar-light bg-light border-bottom" style="padding: 0.5rem 1rem;">
        <div class="d-flex w-100 align-items-center justify-content-between">
            <span class="navbar-brand mb-0 h5">Tienda MVP</span>
            <div class="d-flex gap-2 align-items-center">
                <PWAInstallButton />
                <a href="/pwa-info" class="btn btn-outline-info btn-sm" title="Información sobre PWA">
                    <span>ℹ️</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="d-flex flex-grow-1">
        <SideBar NombreUsuario="Carlos Pérez"
                 Rol="Administrador"
                 Tiendas='new List<string> { "Tienda Norte", "Tienda Centro", "Tienda Sur" }'
                 OnStoreChanged="OnTiendaCambiada" />

        <main class="flex-grow-1 p-4" style="background:#f8f8fc;">
            <CascadingValue Value="@TiendaActual" Name="TiendaActual">
                @Body
            </CascadingValue>
        </main>
    </div>

</div>

@code {
    private string TiendaActual { get; set; } = "Tienda Norte";

    private void OnTiendaCambiada(string tienda)
    {
        TiendaActual = tienda;
    }
}