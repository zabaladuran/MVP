@page "/dashboard"
@layout Layout.MainLayout
@inject IDashboardService DashboardService
@using csharp_app_blazer.Services

<div class="p-4" style="background:#f8f8fc; min-height:100vh;">

    @* Header *@
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-semibold mb-1" style="font-size:22px; color:#14141e;">
                Dashboard · @TiendaActual
            </h2>
            <p class="text-muted mb-0" style="font-size:13px;">Resumen general de la tienda</p>
        </div>
        <div class="px-3 py-2 rounded-3 border" style="font-size:13px; color:#333; background:#fff;">
            Suscripción vence: @SuscripcionVence
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando datos del dashboard...</p>
        </div>
    }
    else
    {
        @* Tarjetas de métricas *@
        <div class="row g-3 mb-4">
            @foreach (var metrica in Metricas)
            {
                <div class="col-6 col-md-3">
                    <div class="bg-white rounded-3 border p-3" style="border-color:#ebebf0 !important;">
                        <p class="text-muted mb-1" style="font-size:12px;">@metrica.Titulo</p>
                        <p class="fw-semibold mb-1" style="font-size:28px; color:#14141e;">
                            @metrica.Valor
                        </p>
                        <p class="mb-0" style="font-size:12px; color:#8c8ca0;">@metrica.Subtitulo</p>
                    </div>
                </div>
            }
        </div>

        @* Tabla de pedidos recientes *@
        <div class="bg-white rounded-3 border p-4" style="border-color:#ebebf0 !important;">

            <h3 class="fw-semibold mb-1" style="font-size:16px; color:#14141e;">
                Pedidos recientes — @TiendaActual
            </h3>
            <p class="text-muted mb-4" style="font-size:13px;">
                Los datos aquí mostrados corresponden únicamente a la tienda seleccionada en el selector superior.
            </p>

            <table class="table table-borderless align-middle" style="font-size:14px;">
                <thead>
                    <tr style="border-bottom:1px solid #ebebf0; color:#6e6e82;">
                        <th class="fw-semibold pb-3">Comprobante</th>
                        <th class="fw-semibold pb-3">Cliente</th>
                        <th class="fw-semibold pb-3">Total</th>
                        <th class="fw-semibold pb-3">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!PedidosRecientes.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No hay pedidos recientes
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var pedido in PedidosRecientes)
                        {
                            <tr style="border-bottom:1px solid #f3f3f6;">
                                <td style="color:#6366f1; font-weight:500;">@pedido.Comprobante</td>
                                <td>@pedido.Cliente</td>
                                <td>@pedido.Total.ToString("C0")</td>
                                <td>
                                    <span class="badge-estado @ObtenerClaseEstado(pedido.Estado)">
                                        @pedido.Estado
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    [CascadingParameter(Name = "TiendaActual")] public string TiendaActual { get; set; } = "TechZone Colombia";

    private bool cargando = true;
    private string SuscripcionVence { get; set; } = "-";
    private List<MetricaItem> Metricas { get; set; } = new();
    private List<PedidoReciente> PedidosRecientes { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        cargando = true;
        var tienda = await DashboardService.ObtenerTiendaPorNombreAsync(TiendaActual);
        if (tienda != null)
        {
            Metricas = await DashboardService.ObtenerMetricasAsync(tienda.Id);
            PedidosRecientes = await DashboardService.ObtenerPedidosRecientesAsync(tienda.Id);
        }
        else
        {
            Metricas = new();
            PedidosRecientes = new();
        }
        cargando = false;
    }

    private string ObtenerClaseEstado(string estado) => estado switch
    {
        "Pendiente" => "estado-pendiente",
        "Entregado" or "Completado" => "estado-completado",
        "Cancelado" => "estado-cancelado",
        _ => "estado-default"
    };
}