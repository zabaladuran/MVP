@page "/productos"
@layout Layout.MainLayout
@using csharp_app_blazer.Services
@inject IDashboardService DashboardService
@inject IProductoService ProductoService
@inject IJSRuntime JS

<div class="p-4" style="background:#f8f8fc; min-height:100vh;">

    @* Header *@
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-semibold mb-1" style="font-size:22px; color:#14141e;">
                Productos · @TiendaActual
            </h2>
            <p class="text-muted mb-0" style="font-size:13px;">Resumen general de la tienda</p>
        </div>
        <div class="px-3 py-2 rounded-3 border" style="font-size:13px; color:#333; background:#fff;">
            Suscripción vence: @SuscripcionVence
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando productos...</p>
        </div>
    }
    else
    {
        @* Barra de filtros y botón nuevo *@
        <div class="d-flex gap-2 mb-3 flex-wrap">
            <input type="text"
                   class="form-control"
                   style="max-width:220px; font-size:13px;"
                   placeholder="Buscar productos..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />

            <select class="form-select" style="max-width:160px; font-size:13px;" @bind="filtroCategoria">
                <option value="">Todas las categorías</option>
                @foreach (var cat in Categorias)
                {
                    <option value="@cat">@cat</option>
                }
            </select>

            <select class="form-select" style="max-width:160px; font-size:13px;" @bind="filtroStock">
                <option value="">Todo el stock</option>
                <option value="disponible">Disponible</option>
                <option value="agotado">Agotado</option>
            </select>

            <button class="btn text-white fw-semibold ms-auto d-flex align-items-center gap-2"
                    style="background:#6366f1; border-radius:8px; font-size:14px;"
                    @onclick="AbrirModalNuevo">
                <i class="ti ti-plus" style="font-size:16px;"></i>
                Nuevo producto
            </button>
        </div>

        @* Tabla de productos *@
        <div class="bg-white rounded-3 border" style="border-color:#ebebf0 !important;">
            <table class="table table-borderless align-middle mb-0" style="font-size:14px;">
                <thead>
                    <tr style="border-bottom:1px solid #ebebf0;">
                        <th class="fw-semibold py-3 px-4" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">PRODUCTO</th>
                        <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">CATEGORÍA</th>
                        <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">PRECIO</th>
                        <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">STOCK</th>
                        <th class="py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!ProductosFiltrados.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                No hay productos registrados
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var producto in ProductosFiltrados)
                        {
                            <tr style="border-bottom:1px solid #f3f3f6;">
                                <td class="px-4">@producto.Nombre</td>
                                <td>@producto.Categoria</td>
                                <td style="color:#6366f1; font-weight:500;">@producto.Precio.ToString("C0")</td>
                                <td>@producto.Stock</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm text-white me-1"
                                            style="background:#6366f1; border-radius:6px; font-size:12px; padding:4px 14px;"
                                            @onclick="() => EditarProducto(producto)">
                                        Edit
                                    </button>
                                    <button class="btn btn-sm text-white"
                                            style="background:#ef4444; border-radius:6px; font-size:12px; padding:4px 14px;"
                                            @onclick="() => EliminarProducto(producto)">
                                        Elim
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }

    @* Modal nuevo / editar producto (componente reutilizable) *@
    @if (mostrarModal && tiendaIdActual.HasValue)
    {
        <ProductoForm TiendaId="tiendaIdActual.Value"
                      Categorias="CategoriasConId"
                      Producto="productoEditando"
                      OnProductoCreado="HandleProductoCreado"
                      OnProductoActualizado="HandleProductoActualizado"
                      OnCancelar="CerrarModal" />
    }

</div>

@code {
    [CascadingParameter(Name = "TiendaActual")] public string TiendaActual { get; set; } = "TechZone Colombia";

    private bool cargando = true;
    private string SuscripcionVence = "31 dic 2025";
    private string textoBusqueda = "";
    private string filtroCategoria = "";
    private string filtroStock = "";
    private bool mostrarModal = false;
    private int? tiendaIdActual;

    private ProductoDbItem? productoEditando = null;

    private List<string> Categorias { get; set; } = new();
    private List<CategoriaFull> CategoriasConId { get; set; } = new();
    private List<ProductoDbItem> ListaProductos { get; set; } = new();

    private IEnumerable<ProductoDbItem> ProductosFiltrados => ListaProductos.Where(p =>
        (string.IsNullOrEmpty(textoBusqueda) || p.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(filtroCategoria) || p.Categoria == filtroCategoria) &&
        (filtroStock == "" ||
         (filtroStock == "disponible" && p.Stock > 0) ||
         (filtroStock == "agotado" && p.Stock == 0))
    );

    protected override async Task OnParametersSetAsync()
    {
        var tienda = await DashboardService.ObtenerTiendaPorNombreAsync(TiendaActual);
        if (tienda != null)
        {
            tiendaIdActual = tienda.Id;
            ListaProductos = await ProductoService.ObtenerProductosAsync(tienda.Id);
            Categorias = await ProductoService.ObtenerCategoriasAsync(tienda.Id);
            CategoriasConId = await ProductoService.ObtenerCategoriasConIdAsync(tienda.Id);
        }
        else
        {
            tiendaIdActual = null;
            ListaProductos = new();
            Categorias = new();
            CategoriasConId = new();
        }
        cargando = false;
    }

    private void AbrirModalNuevo()
    {
        productoEditando = null;
        mostrarModal = true;
    }

    private void EditarProducto(ProductoDbItem p)
    {
        productoEditando = p;
        mostrarModal = true;
    }

    private void HandleProductoCreado(ProductoDbItem producto)
    {
        ListaProductos.Add(producto);
        CerrarModal();
    }

    private void HandleProductoActualizado(ProductoDbItem producto)
    {
        var idx = ListaProductos.FindIndex(p => p.Id == producto.Id);
        if (idx >= 0)
            ListaProductos[idx] = producto;
        CerrarModal();
    }

    private async Task EliminarProducto(ProductoDbItem p)
    {
        if (await MostrarConfirmacion(p.Nombre))
        {
            await ProductoService.EliminarProductoAsync(p.Id);
            ListaProductos.Remove(p);
        }
    }

    private async Task<bool> MostrarConfirmacion(string nombre)
    {
        var mensaje = $"¿Eliminar \"{nombre}\" permanentemente?";
        return await JS.InvokeAsync<bool>("confirm", mensaje);
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        productoEditando = null;
    }
}