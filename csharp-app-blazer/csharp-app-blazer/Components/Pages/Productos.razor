@page "/productos"
@layout Layout.MainLayout
@using csharp_app_blazer.Models

<div class="p-4" style="background:#f8f8fc; min-height:100vh;">

    @* Header *@
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-semibold mb-1" style="font-size:22px; color:#14141e;">
                Productos · @TiendaActual
            </h2>
            <p class="text-muted mb-0" style="font-size:13px;">Resumen general de la tienda</p>
        </div>
        <div class="px-3 py-2 rounded-3 border" style="font-size:13px; color:#333; background:#fff;">
            Suscripción vence: @SuscripcionVence
        </div>
    </div>

    @* Tarjetas de métricas *@
    <div class="row g-3 mb-4">
        @foreach (var metrica in Metricas)
        {
            <div class="col-md-4">
                <div class="bg-white rounded-3 border p-3" style="border-color:#ebebf0 !important;">
                    <p class="text-muted mb-1" style="font-size:12px;">@metrica.Titulo</p>
                    <p class="fw-semibold mb-1" style="font-size:28px; color:#14141e;">@metrica.Valor</p>
                    <p class="mb-0" style="font-size:12px; color:#8c8ca0;">@metrica.Subtitulo</p>
                </div>
            </div>
        }
    </div>

    @* Barra de filtros y botón nuevo *@
    <div class="d-flex gap-2 mb-3 flex-wrap">
        <input type="text"
               class="form-control"
               style="max-width:220px; font-size:13px;"
               placeholder="Buscar productos..."
               @bind="textoBusqueda"
               @bind:event="oninput" />

        <select class="form-select" style="max-width:160px; font-size:13px;" @bind="filtroCategoria">
            <option value="">Todas las categorías</option>
            @foreach (var cat in Categorias)
            {
                <option value="@cat">@cat</option>
            }
        </select>

        <select class="form-select" style="max-width:160px; font-size:13px;" @bind="filtroStock">
            <option value="">Todo el stock</option>
            <option value="disponible">Disponible</option>
            <option value="agotado">Agotado</option>
        </select>

        <button class="btn text-white fw-semibold ms-auto d-flex align-items-center gap-2"
                style="background:#6366f1; border-radius:8px; font-size:14px;"
                @onclick="AbrirModalNuevo">
            <i class="ti ti-plus" style="font-size:16px;"></i>
            Nuevo producto
        </button>
    </div>

    @* Tabla de productos *@
    <div class="bg-white rounded-3 border" style="border-color:#ebebf0 !important;">
        <table class="table table-borderless align-middle mb-0" style="font-size:14px;">
            <thead>
                <tr style="border-bottom:1px solid #ebebf0;">
                    <th class="fw-semibold py-3 px-4" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">PRODUCTO</th>
                    <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">CATEGORÍA</th>
                    <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">PRECIO</th>
                    <th class="fw-semibold py-3" style="font-size:12px; color:#6e6e82; letter-spacing:.05em;">STOCK</th>
                    <th class="py-3"></th>
                </tr>
            </thead>
            <tbody>
                @if (!ProductosFiltrados.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            No hay productos registrados
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var producto in ProductosFiltrados)
                    {
                        <tr style="border-bottom:1px solid #f3f3f6;">
                            <td class="px-4">@producto.Nombre</td>
                            <td>@producto.Categoria</td>
                            <td style="color:#6366f1; font-weight:500;">@producto.Precio.ToString("C0")</td>
                            <td>@producto.Stock</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm text-white me-1"
                                        style="background:#6366f1; border-radius:6px; font-size:12px; padding:4px 14px;"
                                        @onclick="() => EditarProducto(producto)">
                                    Edit
                                </button>
                                <button class="btn btn-sm text-white"
                                        style="background:#ef4444; border-radius:6px; font-size:12px; padding:4px 14px;"
                                        @onclick="() => EliminarProducto(producto)">
                                    Elim
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* Modal nuevo / editar producto *@
    @if (mostrarModal)
    {
        <div class="modal-overlay" @onclick="CerrarModal">
            <div class="modal-card" @onclick:stopPropagation>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-semibold mb-0" style="font-size:16px;">
                        @(productoEditando == null ? "Nuevo producto" : "Editar producto")
                    </h5>
                    <button class="btn btn-sm" @onclick="CerrarModal">
                        <i class="ti ti-x" style="font-size:18px;"></i>
                    </button>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold text-secondary">Nombre</label>
                    <input class="form-control" @bind="formNombre" placeholder="Nombre del producto" />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold text-secondary">Categoría</label>
                    <input class="form-control" @bind="formCategoria" placeholder="Categoría" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col">
                        <label class="form-label small fw-semibold text-secondary">Precio</label>
                        <input type="number" class="form-control" @bind="formPrecio" placeholder="0" />
                    </div>
                    <div class="col">
                        <label class="form-label small fw-semibold text-secondary">Stock</label>
                        <input type="number" class="form-control" @bind="formStock" placeholder="0" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-sm text-white fw-semibold"
                            style="background:#6366f1; border-radius:8px;"
                            @onclick="GuardarProducto">
                        Guardar
                    </button>
                </div>

            </div>
        </div>
    }

</div>

@code {
    [CascadingParameter(Name = "TiendaActual")] public string TiendaActual { get; set; } = "Tienda Norte";

    private string SuscripcionVence = "31 dic 2025";
    private string textoBusqueda = "";
    private string filtroCategoria = "";
    private string filtroStock = "";
    private bool mostrarModal = false;

    // Formulario modal
    private string formNombre = "";
    private string formCategoria = "";
    private decimal formPrecio = 0;
    private int formStock = 0;
    private ProductoItem? productoEditando = null;

    private List<MetricaItem> Metricas = new()
    {
        new("Título", 0, "pruebaaa"),
        new("Título", 0, "pruebaaa"),
        new("Título", 0, "pruebaaa"),
    };

    private List<string> Categorias = new() { "Categoría A", "Categoría B" };

    private List<ProductoItem> ListaProductos = new()
    {
        new(1, "Producto", "Categoría", 0, 0),
    };

    private IEnumerable<ProductoItem> ProductosFiltrados => ListaProductos.Where(p =>
        (string.IsNullOrEmpty(textoBusqueda) || p.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(filtroCategoria) || p.Categoria == filtroCategoria) &&
        (filtroStock == "" ||
         (filtroStock == "disponible" && p.Stock > 0) ||
         (filtroStock == "agotado" && p.Stock == 0))
    );

    private void AbrirModalNuevo()
    {
        productoEditando = null;
        formNombre = "";
        formCategoria = "";
        formPrecio = 0;
        formStock = 0;
        mostrarModal = true;
    }

    private void EditarProducto(ProductoItem p)
    {
        productoEditando = p;
        formNombre = p.Nombre;
        formCategoria = p.Categoria;
        formPrecio = p.Precio;
        formStock = p.Stock;
        mostrarModal = true;
    }

    private void GuardarProducto()
    {
        if (productoEditando == null)
        {
            var nuevoId = ListaProductos.Any() ? ListaProductos.Max(p => p.Id) + 1 : 1;
            ListaProductos.Add(new(nuevoId, formNombre, formCategoria, formPrecio, formStock));
        }
        else
        {
            var idx = ListaProductos.IndexOf(productoEditando);
            ListaProductos[idx] = productoEditando with
            {
                Nombre = formNombre,
                Categoria = formCategoria,
                Precio = formPrecio,
                Stock = formStock
            };
        }
        CerrarModal();
    }

    private void EliminarProducto(ProductoItem p) => ListaProductos.Remove(p);

    private void CerrarModal()
    {
        mostrarModal = false;
        productoEditando = null;
    }
}