@page "/admin/login"
@using csharp_app_blazer.Services
@using csharp_app_blazer.Models
@inject IAuthAdminService AuthAdminService
@inject NavigationManager Navigation
@inject AuthStateService AuthState
@inject IJSRuntime JS
@layout Layout.EmptyLayout

<div class="min-vh-100 d-flex align-items-center justify-content-center"
     style="background-color: #0f0f23;">

    <div class="card border-0 shadow p-4"
         style="width: 420px; border-radius: 16px; background:#1a1a2e;">

        @if (!string.IsNullOrEmpty(errorMensaje))
        {
            <div class="alert alert-danger alert-dismissible py-2 px-3 mb-3" role="alert">
                <small>@errorMensaje</small>
                <button type="button" class="btn-close btn-sm" @onclick="() => errorMensaje = string.Empty"></button>
            </div>
        }

        <div class="d-flex justify-content-center mb-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:72px; height:72px; background-color:#e94560;">
                <i class="bi bi-shield-lock-fill fs-2 text-white"></i>
            </div>
        </div>

        <h1 class="text-center fs-4 fw-semibold mb-1" style="color:#fff;">Admin Panel</h1>
        <p class="text-center mb-2" style="color:#8c8ca0; font-size:13px;">Ingresa tus credenciales de administrador</p>

        <div class="mx-auto mb-4"
             style="width:48px; height:3px; background-color:#e94560; border-radius:2px;">
        </div>

        <EditForm Model="Input" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label small fw-semibold" style="color:#8c8ca0;">Correo</label>
                <InputText @bind-Value="Input.Correo"
                           class="form-control"
                           placeholder="admin@mvp.com"
                           style="background:#16213e; color:#fff; border-color:#2a2a4a;" />
                <ValidationMessage For="() => Input.Correo" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold" style="color:#8c8ca0;">Contraseña</label>
                <InputText @bind-Value="Input.Password"
                           type="password"
                           class="form-control"
                           placeholder="Escribe tu contraseña"
                           style="background:#16213e; color:#fff; border-color:#2a2a4a;" />
                <ValidationMessage For="() => Input.Password" class="text-danger small" />
            </div>

            <button type="submit"
                    class="btn w-100 text-white fw-semibold py-2 mt-2"
                    style="background-color:#e94560; border-radius:8px;"
                    disabled="@cargando">
                @if (cargando)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                Ingresar
            </button>

        </EditForm>

        <a href="/login" class="d-block text-center mt-3 small" style="color:#e94560;">
            ← Volver al inicio de sesión de tienda
        </a>

        <p class="text-center mb-0 mt-2" style="font-size: 11px; color:#4a4a6a;">
            v1.0.0 · Panel de administración
        </p>

    </div>
</div>

@code {
    private AdminLoginViewModel Input { get; set; } = new();
    private string errorMensaje = string.Empty;
    private bool cargando = false;

    private async Task HandleLogin()
    {
        cargando = true;
        errorMensaje = string.Empty;

        try
        {
            var resultado = await AuthAdminService.LoginAsync(Input.Correo, Input.Password);

            if (!resultado.Exitoso)
            {
                errorMensaje = resultado.Mensaje;
                cargando = false;
                return;
            }

            await AuthState.IniciarSesionAdminAsync(JS, resultado);
            Navigation.NavigateTo("/admin/dashboard");
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }
}
